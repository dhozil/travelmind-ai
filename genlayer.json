{
  "name": "TravelMind AI",
  "description": "AI-powered travel recommendation platform with multi-validator consensus on GenLayer.",
  "version": "1.0.0",
  "network": "testnet-bradbury",
  "contracts": {
    "TravelMindAI": {
      "file": "contracts/TravelMindAI.py",
      "name": "TravelMind AI",
      "description": "Unified contract: AI recommendations, itineraries, travel match, hidden gems, on-chain storage",
      "address": "0x6858C53D519CBE7C5f1149B262Ea7B30E618273f",
      "validators": [
        { "id": "alpha", "model": "gpt-4", "weight": 1 },
        { "id": "beta", "model": "claude-3", "weight": 1 },
        { "id": "gamma", "model": "gemini-pro", "weight": 1 }
      ],
      "consensus_threshold": 0.67,
      "public_methods": [
        "recommend", "generate_itinerary", "match_by_image",
        "find_hidden_gems", "save_trip", "save_recommendation",
        "get_last_recommendation", "get_last_itinerary", "get_last_match", "get_last_gems",
        "get_trip", "get_recommendation", "get_user_trips",
        "get_user_recommendations", "get_stats"
      ]
    }
  },
  "frontend_integration": {
    "client_lib": "lib/genlayer.ts",
    "required_env_vars": [
      "NEXT_PUBLIC_GENLAYER_RPC_URL",
      "NEXT_PUBLIC_GENLAYER_CONTRACT_ADDRESS"
    ],
    "wallet_integration": "genlayer-js"
  },
  "deployment": {
  "network": "testnet-bradbury",
    "gas_limit": 5000000,
    "confirmations": 2
  }
}
